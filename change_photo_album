#! /usr/bin/env bash

set -eux
set -o pipefail

declare -r BASE_DIR="$(dirname "$(readlink -e "$0")")"
source "$BASE_DIR/lib/directories.sh"
source "$BASE_DIR/lib/photoid.sh"

PATH="$BASE_DIR/metadata:$BASE_DIR:$PATH"


function lookupOldAlbumName() {
    local photofile=$1
    
    # get album name from path (album directory)
    old_album_path=$(directories_get_albumpath_from_file "$file")
    old_album=${old_album_path##*/}

    if [[ $old_album =~ - ]]; then
        echo "${old_album//-/ }"
    else
        echo "$old_album"
    fi
}


while getopts "taof:" opt; do
    case $opt in
        t ) CHANGE_PHOTO_TITLES_TO_ALBUM_NAME=;;
        a ) ADD_NEW_ALBUM_KEYWORD=;;
        o ) REMOVE_OLD_ALBUM_KEYWORD=;;
        f )
            mapfile -t PHOTO_FILES < "$OPTARG";;
	esac
done
shift $(expr $OPTIND - 1 )


declare -r NEW_ALBUM=$1
if [[ -f $NEW_ALBUM || -d $NEW_ALBUM ]]; then
	echo "[ERROR] Album parameter is a file or directory" >&2
	exit 1
fi
shift 1


if ! [[ -v PHOTO_FILES ]] && [[ $# -gt 0 ]]; then
    PHOTO_FILES=("$@")
elif ! [[ -v PHOTO_FILES ]] || [[ ${#PHOTO_FILES[@]} -eq 0 ]]; then
    echo "[ERROR] No photos" >&2
    exit 1
fi


safe_new_album=$(tr ' ' '-' <<<"$NEW_ALBUM")
for photo in "${PHOTO_FILES[@]}"; do

    echo "[INFO] Moving $photo to new album \"$NEW_ALBUM\"" >&2


    old_album_path=$(directories_get_albumpath_from_file "$photo")
    relative_to_album_path=${photo#$old_album_path/}
    new_album_parent=${old_album_path%/*}
    newfullpath="$new_album_parent/$NEW_ALBUM/$relative_to_album_path"

    if [[ -e $newfullpath ]]; then
        echo "[ERROR] Cannot move $photo to $NEW_ALBUM, file exists already" >&2
        continue
    fi

    if [[ -v REMOVE_OLD_ALBUM_KEYWORD ]]; then
        old_album_name=$(lookupOldAlbumName "$photo")
    fi

    new_parentdir="$(dirname "$newfullpath")"
    if ! [[ -e $new_parentdir ]]; then
        mkdir --parents "$new_parentdir"
    fi
    collect_associated_files "$photo" | while read -r file_in_old_album; do 

        if [[ -v REMOVE_OLD_ALBUM_KEYWORD ]]; then
            echo "update_keywords \"-$old_album_name\" \"$file_in_old_album\"" >&2
        fi

        if [[ -v ADD_NEW_ALBUM_KEYWORD ]]; then
            echo "update_keywords \"$NEW_ALBUM\" \"$file_in_old_album\"" >&2
        fi    

        file_in_new_album="$new_parentdir/$(basename "$file_in_old_album")"
        echo "mv \"$file_in_old_album\" \"$file_in_new_album\"" >&2
        echo "$file_in_new_album"

    done

    if [[ -v CHANGE_PHOTO_TITLES_TO_ALBUM_NAME ]]; then
        echo "change_photo_title \"$NEW_ALBUM\" \"$newfullpath\"" >&2
    fi

done
